# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-side only, NEVER expose

# --- NAS scraper API ---
NAS_API_URL=https://tripwatch-nas.YOUR_CLOUDFLARE_TUNNEL.com
NAS_API_KEY=                            # shared bearer token, generate with: openssl rand -hex 32

# --- Telegram (existing bot) ---
TELEGRAM_BOT_TOKEN=                     # same token already on NAS
TELEGRAM_BOT_USERNAME=RaniTripWatchBot

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM=noreply@tripwatch.vercel.app

# --- Cron auth ---
CRON_SECRET=                            # protect /api/cron/* from random POSTs
